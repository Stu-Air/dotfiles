# themes
include qogir_dark.conf
#include Wryan.conf
#include VSCode_Dark.conf

# terminal opacity and blur
background_opacity 0.98
background_blur 1


# os specific tweaks (Gnome window decoration for wayland)
#linux_display_server x11

# font
font_family      family="FiraCode Nerd Font Mono"
bold_font        family='FiraCode Nerd Font Mono' postscript_name=FiraCodeNFM-Bold
italic_font      auto
bold_italic_font auto
font_size 12.0

# cursor customization
# block / beam / underline
cursor_shape block
cursor_blink_interval 0
cursor_stop_blinking_after 0
shell_integration no-cursor

# scrollback
scrollback_lines 5000
wheel_scroll_multiplier 3.0

# mouse
mouse_hide_wait -1

# window layout
remember_window_size  no
initial_window_width  1220
initial_window_height 800
window_border_width 1.5pt
enabled_layouts tall
window_padding_width 2
window_margin_width 2
hide_window_decorations no

# tab bar customization
tab_bar_style powerline
tab_powerline_style slanted
tab_bar_edge bottom
tab_bar_align left
active_tab_font_style   bold
inactive_tab_font_style normal
